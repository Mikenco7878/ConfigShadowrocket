# !name=LightRoom
# !desc=Adobe LightRoom Unlock

[MITM]
hostname = %APPEND% photos.adobe.io

[Script]
LightRoom = type=http-response,pattern=^https:\/\/photos\.adobe\.io\/v2\/accounts*,requires-body=1,script-path=https://raw.githubusercontent.com/Mikenco7878/ConfigShadowrocket/main/scripts/lightroom.js