# !name=Picsart
# !desc=picsart pro

[Script]
Picsart = type=http-response,pattern=https:\/\/api\.(picsart|meiease)\.c(n|om)\/users\/show\/me\.json,requires-body=1,max-size=0,script-path=https://raw.githubusercontent.com/Mikenco7878/ConfigShadowrocket/main/scripts/PicsArt.js

[MITM]
hostname = %APPEND% api.picsart.c*, api.meiease.c*